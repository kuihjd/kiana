DRIVER=~fastapi+~httpx+~websockets
COMMAND_START=["/", ""]
APSCHEDULER_CONFIG={ "apscheduler.timezone": "Asia/Shanghai" }
SUPERUSERS=[""]
NICKNAME=[""]

# ONEBOT_ACCESS_TOKEN=


# ========== Gold 插件配置 ==========
# 金价插件全局开关，默认true
# gold_plugin_enabled=true

# 功能开关
# 是否启用金价查询功能，默认true
# gold_enable_price_query=true
# 是否启用金价走势图功能，默认true
# gold_enable_chart=true

# 分群配置
# 群组控制模式，可选值: all/whitelist/blacklist
# gold_group_mode=all
# 白名单群组（仅在 whitelist 模式生效），格式: ["群号1", "群号2"]
# gold_group_whitelist=[]
# 黑名单群组（仅在 blacklist 模式生效），格式: ["群号1", "群号2"]
# gold_group_blacklist=[]

# 功能配置
# 冷却时间（秒），默认1秒
# cooldown_time=1
# 金价获取间隔时间（秒），默认600秒
# price_fetch_interval=600
# 趋势图展示的时间窗口（小时），默认120小时
# chart_window_hours=120
# 内存中保留的历史数据最大数量，默认86400条
# price_history_limit=86400
# 趋势图最小时间窗口（秒），默认3600秒（1小时）
# min_window_seconds=3600


# ========== Doubili 插件配置 ==========
# 平台解析开关
# 是否启用B站解析，默认true
# enable_bilibili=true
# 是否启用抖音解析，默认true
# enable_douyin=true
# 是否启用小红书解析，默认true
# enable_xiaohongshu=true
# 小红书 cookie，解析分享卡片必须，直链可以不要
# xiaohongshu_cookie=

# Bilibili 分群配置
# bilibili_group_mode=all 可选值: all/whitelist/blacklist
# bilibili_group_whitelist=[]
# bilibili_group_blacklist=[]

# Douyin 分群配置
# douyin_group_mode=all
# douyin_group_whitelist=[]
# douyin_group_blacklist=[]

# Xiaohongshu 分群配置
# xiaohongshu_group_mode=all
# xiaohongshu_group_whitelist=[]
# xiaohongshu_group_blacklist=[]


# ========== Fund 插件配置 ==========
# 基金查询插件全局开关，默认true
# fund_plugin_enabled=true

# 分群配置
# 群组控制模式，可选值: all/whitelist/blacklist
# fund_group_mode=all
# 白名单群组，格式: ["群号1", "群号2"]
# fund_group_whitelist=[]
# 黑名单群组，格式: ["群号1", "群号2"]
# fund_group_blacklist=[]

# 数据获取配置
# 获取历史数据天数（1-365），默认30天
# fund_history_days=30
# 显示最近交易日天数（1-30），默认7天
# fund_display_recent_days=7

# 缓存配置
# 缓存有效期（分钟，1-60），默认5分钟
# fund_cache_ttl_minutes=5
# 最大缓存条目数（10-1000），默认100条
# fund_max_cache_size=100

# 功能开关
# 是否启用ETF查询，默认true
# fund_enable_etf=true
# 是否启用LOF查询，默认true
# fund_enable_lof=true
# 是否启用股票查询，默认true
# fund_enable_stocks=true
# 是否启用场外基金查询，默认true
# fund_enable_off_market=true
# 是否启用指数查询，默认true
# fund_enable_index=true
# 是否启用数据源切换（东方财富→同花顺），默认true
# fund_enable_data_source_fallback=true


# ========== Gotify 转发插件配置 ==========
# 插件开关，默认false
# gotify_plugin_enabled=false
# Gotify 服务器地址
# gotify_url=https://gotify.example.com
# Gotify Client Token
# gotify_client_token=
# 转发目标 QQ 用户 ID，格式: ["用户ID1", "用户ID2"]
# gotify_forward_users=[]
# 转发目标 QQ 群号，格式: ["群号1", "群号2"]
# gotify_forward_groups=[]
# 断线重连间隔（秒），默认5秒，会指数退避
# gotify_reconnect_interval=5


# ========== A 股情绪指数插件配置 ==========
# 命令：本群情绪 / 今日情绪

# 插件全局开关，默认false
# a_share_sentiment_plugin_enabled=false

# 分群配置
# 群组控制模式，可选值: all/whitelist/blacklist
# a_share_sentiment_group_mode=all
# 白名单群组，格式: ["群号1", "群号2"]
# a_share_sentiment_group_whitelist=[]
# 黑名单群组，格式: ["群号1", "群号2"]
# a_share_sentiment_group_blacklist=[]

# AI 接口配置（OpenAI 兼容）
# 例如 OpenAI 官方可填 https://api.openai.com/v1
# a_share_sentiment_base_url=https://api.openai.com/v1
# a_share_sentiment_api_key=sk-xxxx
# a_share_sentiment_model=gpt-4.1-mini

# 请求配置
# 超时时间（秒），默认30
# a_share_sentiment_timeout_seconds=30
# 温度参数（0-2），默认0.2
# a_share_sentiment_temperature=0.2

# 分析配置
# 历史对比天数，默认5
# a_share_sentiment_history_days=5
# 低于该文本消息数时仍分析，但会标低置信度，默认20
# a_share_sentiment_min_messages=20

# Prompt 预算配置
# 今日最多采样消息条数，默认200
# a_share_sentiment_max_today_messages=200
# 历史每天最多采样消息条数，默认40
# a_share_sentiment_max_history_messages_per_day=40
# 今日样本文本字符预算，默认12000
# a_share_sentiment_max_prompt_chars_today=12000
# 历史每天样本文本字符预算，默认4000
# a_share_sentiment_max_prompt_chars_history_day=4000

# 成本控制
# 同一群查询冷却时间（秒），默认300
# a_share_sentiment_cooldown_seconds=300
# 同一群同一天结果缓存时间（分钟），默认10
# a_share_sentiment_cache_ttl_minutes=10


# ========== 昵称 插件配置 ==========
# 最大昵称长度，默认15
# max_nickname_length=15
